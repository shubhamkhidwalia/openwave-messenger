# ═══════════════════════════════════════════════════════════
#   OpenWave — Environment Variables
#   Copy this file to  backend/.env  and fill every value
# ═══════════════════════════════════════════════════════════

# ── Server ────────────────────────────────────────────────
PORT=4000
NODE_ENV=production

# ── Security (CHANGE THESE — never use the defaults!) ─────
# Generate at: https://generate-secret.vercel.app/64
JWT_SECRET=replace-with-64-char-random-string-here

# Your personal admin password for generating invite links
ADMIN_SECRET=replace-with-your-own-secret-word

# ── Turso Cloud Database ───────────────────────────────────
# Free at https://turso.tech
# After creating a DB run:
#   turso db show openwave --url     (paste as TURSO_URL)
#   turso db tokens create openwave  (paste as TURSO_TOKEN)
TURSO_URL=libsql://your-db-name-yourname.turso.io
TURSO_TOKEN=your-turso-token-here

# ── Cloudinary File Storage ────────────────────────────────
# Free at https://cloudinary.com  (25 GB free)
# Dashboard → Settings → API Keys
CLOUDINARY_NAME=your-cloud-name
CLOUDINARY_KEY=your-api-key
CLOUDINARY_SECRET=your-api-secret

# ── App URL (update when deployed online) ─────────────────
APP_URL=http://localhost:4000

# ── CORS (update to your domain when deployed) ────────────
CLIENT_ORIGIN=*
