# OpenWave Environment Configuration
# Copy this file to .env and fill in your values

# Server
PORT=4000
NODE_ENV=production

# Security — CHANGE THIS to a long random string in production!
JWT_SECRET=replace-with-a-secure-random-string-at-least-32-chars

# CORS — set to your frontend domain in production
CLIENT_ORIGIN=https://yourdomain.com

# Optional: custom data directory
# DATA_DIR=/var/lib/openwave
# UPLOADS_DIR=/var/lib/openwave/uploads
